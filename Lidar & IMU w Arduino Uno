#include <Wire.h>
#include <Adafruit_BNO055.h>
#include <Adafruit_Sensor.h>
#include <SoftwareSerial.h>
 
// TFmini on SoftwareSerial
SoftwareSerial tfSerial(10, 11); // RX, TX
 
Adafruit_BNO055 bno = Adafruit_BNO055(55, 0x28);
 
void setup() {
  Serial.begin(115200);     // USB output
  tfSerial.begin(115200);   // TFmini
 
  if (!bno.begin()) {
    Serial.println("No BNO055 detected");
    while (1);
  }
 
  delay(1000);
  Serial.println("Both sensors running (UNO)");
}
 
void loop() {
 
  // IMU READ
  sensors_event_t event;
  bno.getEvent(&event);
 
  Serial.print("IMU -> ");
  Serial.print("X:");
  Serial.print(event.orientation.x);
  Serial.print(" Y:");
  Serial.print(event.orientation.y);
  Serial.print(" Z:");
  Serial.print(event.orientation.z);
 
  Serial.print(" | ");

  // LiDAR READ
  if (tfSerial.available() >= 9) {
 
    if (tfSerial.read() == 0x59 && tfSerial.read() == 0x59) {
 
      uint8_t data[7];
      for (int i = 0; i < 7; i++) {
        data[i] = tfSerial.read();
      }
 
      uint16_t distance = data[0] | (data[1] << 8);
 
      Serial.print("LiDAR:");
      Serial.print(distance);
      Serial.print("cm");
    }
  }
 
  Serial.println();
 
  delay(100); // readable output
}
