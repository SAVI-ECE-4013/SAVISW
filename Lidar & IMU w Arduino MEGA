#include <Wire.h>
#include <Adafruit_BNO055.h>
#include <Adafruit_Sensor.h>
#include <SoftwareSerial.h>
 
SoftwareSerial tfSerial(10, 11); // RX, TX
Adafruit_BNO055 bno = Adafruit_BNO055(55, 0x28);
 
void setup() {
  Serial.begin(115200);
  tfSerial.begin(115200);
 
  if (!bno.begin()) {
    Serial.println("No BNO055 detected");
    while (1);
  }
 
  delay(1000);
  Serial.println("Both sensors running (UNO)");
}
 
void loop() {
  sensors_event_t event;
  bno.getEvent(&event);
 
  Serial.print("IMU -> ");
  Serial.print("X:");
  Serial.print(event.orientation.x);
  Serial.print(" Y:");
  Serial.print(event.orientation.y);
  Serial.print(" Z:");
  Serial.print(event.orientation.z);
  Serial.print(" | ");
 
  bool gotLidar = false;
 
  while (tfSerial.available() >= 9) {
    if (tfSerial.read() == 0x59) {
      if (tfSerial.read() == 0x59) {
        uint8_t data[7];
        for (int i = 0; i < 7; i++) {
          data[i] = tfSerial.read();
        }
 
        uint16_t distance = data[0] | (data[1] << 8);
        uint16_t strength = data[2] | (data[3] << 8);
 
        uint8_t checksum = 0x59 + 0x59;
        for (int i = 0; i < 6; i++) {
          checksum += data[i];
        }
 
        if ((checksum & 0xFF) == data[6]) {
          // basic sanity filter
          if (distance > 0 && distance < 1200 && strength > 20) {
            Serial.print("LiDAR:");
            Serial.print(distance);
            Serial.print("cm");
          } else {
            Serial.print("LiDAR: invalid");
          }
          gotLidar = true;
          break;
        }
      }
    }
  }
 
  if (!gotLidar) {
    Serial.print("LiDAR: no valid frame");
  }
 
  Serial.println();
  delay(100);
}
